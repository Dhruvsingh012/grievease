# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment Variables (NEVER commit these) ────────────────────────────────
.env
*.env
!.env.example

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
!database/grievease.db

# ── Uploads ───────────────────────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

