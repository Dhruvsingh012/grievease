# ── GrievEase Environment Variables ──────────────────────────────────────────
# Copy this to .env and fill in your actual values.

DATABASE_URL=sqlite:///./grievease.db
# For PostgreSQL: postgresql://username:password@host:5432/dbname
# For Neon:       postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

SECRET_KEY=your-secret-key-min-32-characters-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

APP_NAME=GrievEase
APP_VERSION=3.0.0
DEBUG=False

FRONTEND_URL=https://your-app.vercel.app

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=GrievEase <noreply@your-domain.com>

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
